// Yerel dev için SQLite kullanılıyor. Production PostgreSQL'e geçiş için:
// 1. provider = "postgresql" yap
// 2. gallery ve techStack alanlarını String -> String[] yap (PostgreSQL array)
// 3. DATABASE_URL'i PostgreSQL connection string'e çevir
// 4. pnpm prisma migrate dev

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String
  ctaText   String?
  ctaUrl    String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  subtitle       String?
  heroImageUrl   String?
  content        String // TipTap HTML
  seoTitle       String?
  seoDescription String?
  updatedAt      DateTime @updatedAt
}

model Service {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  shortDesc      String
  icon           String?
  coverImage     String?
  content        String
  order          Int      @default(0)
  isActive       Boolean  @default(true)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Project {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  client         String?
  category       String // tag — "Pazaryeri", "B2B", "Mobil", "E-ticaret", "ERP", "Platform", "Uygulama"
  sector         String? // "Eczane", "Kozmetik", "Kurumsal", "Hırdavat", "Aksesuar" ...
  status         String   @default("Yayında") // "Yayında" | "Beta" | "Yakında"
  hue            Int? // decorative color hue for gradient placeholders (0-360)
  shortDesc      String
  content        String
  coverImage     String
  gallery        String   @default("[]")
  techStack      String   @default("[]")
  liveUrl        String?
  year           Int?
  isFeatured     Boolean  @default(false)
  order          Int      @default(0)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category])
  @@index([sector])
  @@index([isFeatured])
}

model Sector {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  detail    String
  // count alanı projelere bakılarak da türetilebilir ama admin'in override edebilmesi için
  countOverride Int?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AboutValue {
  id          String   @id @default(cuid())
  eyebrow     String // "ODAK", "YAKLAŞIM" vb.
  title       String // "Uçtan uca ürün geliştirme"
  description String // alt açıklama
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  tag         String // "Ürün" | "Sektör" | "Kültür"
  title       String
  excerpt     String
  content     String // TipTap HTML
  coverImage  String?
  publishedAt DateTime @default(now())
  isPublished Boolean  @default(true)
  seoTitle       String?
  seoDescription String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@index([publishedAt])
}

model Client {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String?
  websiteUrl String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Career {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  department String // team (e.g. "i-eczane", "merkez")
  location   String
  type       String // "Tam Zamanlı" | "Yarı Zamanlı"
  shortDesc  String
  content    String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  path      String
  mimeType  String
  size      Int
  width     Int?
  height    Int?
  alt       String?
  createdAt DateTime @default(now())
}

model SiteSetting {
  id              String   @id @default("singleton")
  siteName        String   @default("i-group")
  logoUrl         String?
  faviconUrl      String?
  tagline         String?
  email           String?
  phone           String?
  address         String?
  whatsapp        String?
  linkedinUrl     String?
  instagramUrl    String?
  xUrl            String?
  footerText      String?
  defaultSeoTitle String?
  defaultSeoDesc  String?
  gtmId           String?
  // Kurumsal stats
  statProjects    Int      @default(13)
  statSectors     Int      @default(6)
  statYears       Int      @default(10)
  statEndUsers    String   @default("120K")
  teamSize        Int      @default(38)
  foundedYear     Int      @default(2014)
  // Hero & About kopyaları
  heroHeading       String? // "Eczane, kozmetik ve B2B için ürün geliştiriyoruz."
  heroHighlight     String? // "ürün geliştiriyoruz." kısmı
  heroSubtitle      String?
  heroStatusText    String? // "İstanbul merkezli ürün stüdyosu · 2014'ten beri"
  heroImageUrl      String?
  aboutHeading      String?
  aboutLead         String?
  aboutImage1       String?
  aboutImage2       String?
  aboutImage3       String?
  careersHeading    String?
  careersLead       String?
  careersImage      String?
  contactHeading    String? // "Bir proje mi düşünüyorsunuz?"
  contactHighlight  String? // "proje"
  contactLead       String?
  officeHours       String? // "Pazartesi – Cuma · 09:30 – 18:30"
  // Hero CTA'ları
  heroCtaPrimaryLabel    String?
  heroCtaPrimaryUrl      String?
  heroCtaSecondaryLabel  String?
  heroCtaSecondaryUrl    String?
  // Hero overlay kartı
  heroOverlayLabel       String?
  heroOverlayTitle       String?
  heroOverlayDescription String?
  // Careers empty state
  careersEmptyTitle      String?
  careersEmptyText       String?
  careersApplyLabel      String?
  // Projects section
  projectsEyebrow   String?
  projectsTitle     String?
  projectsLead      String?
  // Sectors section
  sectorsEyebrow    String?
  sectorsTitle      String?
  sectorsLead       String?
  // Clients section
  clientsEyebrow    String?
  clientsTitle      String?
  clientsLead       String?
  // Blog section
  blogEyebrow       String?
  blogTitle         String?
  blogLead          String?
  updatedAt       DateTime @updatedAt
}
