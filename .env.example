# Database
# Yerel dev (varsayılan): SQLite
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL) — Hostinger VPS / CloudPanel için:
# DATABASE_URL="postgresql://user:pass@localhost:5432/igrup?schema=public"

# NextAuth
# openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Seed admin kullanıcı bilgileri (ilk seed sırasında oluşturulur)
ADMIN_EMAIL="admin@i-grup.com"
ADMIN_PASSWORD="changeme-please"
ADMIN_NAME="Admin"

# Mail — biri seçilsin
# Resend (kolay)
RESEND_API_KEY=""
# veya SMTP
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@i-grup.com"

# Uploads
UPLOAD_DIR="./public/uploads"
MAX_UPLOAD_SIZE_MB="5"

# Public
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
